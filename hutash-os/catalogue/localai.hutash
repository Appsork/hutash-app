# LocalAI — drop-in compatible local AI API.
# .hutash catalogue declaration (read by hutash-os for display, by hutashd for install).
id: localai
name: LocalAI
version: "2.0"
type: app
license: MIT

# Execution path: a web server run as a container (official pre-built image,
# pulled and run directly — its own entrypoint runs, no pip package/entrypoint).
# CPU image: the GPU image (…-gpu-nvidia-cuda-12) is heavy and needs special CUDA
# wiring inside WSL2; the plain image runs in CPU mode without that setup.
app_type: web-container
image: localai/localai:latest

ports:
  - internal: 8080

health:
  endpoint: /readyz
  start_period_seconds: 180

# Shared shelf: the host's shared model store is bind-mounted at /models (and
# MODELS_PATH points LocalAI there), so a model downloaded by any app is reused.
env_vars:
  MODELS_PATH: "/models"

mount_paths:
  - host: "{HUTASH_BASE}/models"
    container: /models

metadata:
  description: "OpenAI-compatible local AI. LLMs, images, audio on any hardware."
  category: llm
  homepage: https://github.com/mudler/LocalAI
  model_shelf: shared
