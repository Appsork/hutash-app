# LocalAI — drop-in compatible local AI API.
# .hutash catalogue declaration (read by hutash-os for display, by hutashd for install).
id: localai
name: LocalAI
version: "2.0"
type: app
license: MIT

# Execution path: a web server run as a container (official pre-built GPU image,
# pulled and run directly — its own entrypoint runs, no pip package/entrypoint).
# The GPU image is the one confirmed working (LocalAI v4.4.3 serving on :8080 with
# the model store bind-mounted): `nerdctl run --gpus all -p 8080:8080
# -v <base>/models:/models -e MODELS_PATH=/models localai/localai:latest-gpu-nvidia-cuda-12`.
app_type: web-container
image: localai/localai:latest-gpu-nvidia-cuda-12

runtime:
  gpu_required: true

ports:
  - internal: 8080

health:
  endpoint: /healthz
  start_period_seconds: 180

# Shared shelf: the host's shared model store is bind-mounted at /models (and
# MODELS_PATH points LocalAI there), so a model downloaded by any app is reused.
env_vars:
  MODELS_PATH: "/models"

mount_paths:
  - host: "{HUTASH_BASE}/models"
    container: /models

metadata:
  description: "OpenAI-compatible local AI. LLMs, images, audio on any hardware."
  category: llm
  homepage: https://github.com/mudler/LocalAI
  model_shelf: shared
