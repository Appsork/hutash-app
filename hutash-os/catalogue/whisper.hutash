# Whisper ASR — transcribe audio to text locally.
# .hutash catalogue declaration (read by hutash-os for display, by hutashd for install).
id: whisper
name: Whisper ASR
version: "1.0"
type: app
license: MIT

# Execution path: a web server run as a container (pre-built image, pulled and
# run directly — its own entrypoint runs, no pip package/entrypoint). CPU image:
# the -gpu tag needs special CUDA wiring inside WSL2; the plain tag runs on CPU.
app_type: web-container
image: onerahmet/openai-whisper-asr-webservice:latest

ports:
  - internal: 9000

health:
  endpoint: /docs
  start_period_seconds: 120

metadata:
  description: "Transcribe audio to text locally using OpenAI Whisper."
  category: audio
  homepage: https://github.com/ahmetoner/whisper-asr-webservice
  model_shelf: isolated
